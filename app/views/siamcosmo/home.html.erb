<% content_for :title, t("siamcosmo") %>

<div class="welcome">
  <h1 class="logo-text">
    <span class="logo-siam">Siam</span><span class="logo-cosmo">Cosmo</span>
  </h1>
  <p>ศูนย์การค้าออนไลน์เพื่อชุมชน</p>
</div>

<div class="calculator-cta">
  <a href="/calculator" class="calculator-btn">
    <span class="calc-icon">🧮</span>
    <span class="calc-text">
      <span class="calc-title">คำนวณราคาวัสดุ</span>
      <span class="calc-subtitle">ประเมินค่าใช้จ่ายงานก่อสร้าง</span>
    </span>
    <span class="calc-arrow">→</span>
  </a>
</div>

<div class="services-slider-container">
  <div class="services-slider" id="servicesSlider">
    <% @services.each do |service| %>
      <a href="/chat/<%= service.key %>" class="service-slide">
        <div class="service-icon"><%= service.icon %></div>
        <div class="service-info">
          <h3 class="service-name"><%= service.name(I18n.locale) %></h3>
          <span class="service-providers">
            <%= service.providers_count %> ผู้ให้บริการ
          </span>
        </div>
        <div class="service-arrow">→</div>
      </a>
    <% end %>
  </div>
  
  <div class="slider-nav">
    <button class="slider-btn prev" onclick="slideServices(-1)">❮</button>
    <button class="slider-btn next" onclick="slideServices(1)">❯</button>
  </div>
  
  <div class="slider-dots" id="sliderDots"></div>
</div>

<script>
function slideServices(direction) {
  const slider = document.getElementById('servicesSlider');
  const slideWidth = slider.querySelector('.service-slide').offsetWidth + 12;
  slider.scrollBy({ left: direction * slideWidth * 3, behavior: 'smooth' });
}
</script>
