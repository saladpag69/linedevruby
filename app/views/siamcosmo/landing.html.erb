<% content_for :title, t("landing.title") %>

<!-- ═══════════════════════════════════════════════════════════════════════════
     SECTION 4: SERVICES SHOWCASE - แสดงบริการที่มี
     - Card-based design พร้อม icon
     - Hover effects สำหรับ engagement
     - Provider count แสดงความ popular
═══════════════════════════════════════════════════════════════════════════ -->
<section class="services-showcase" id="services">
  <div class="hero-services-wrapper">
    <div class="hero-services-cta">
      <div class="cta-icon">🛠️</div>
      <h3 class="cta-title">เลือกบริการที่คุณต้องการ</h3>
      <p class="cta-desc">แตะที่ไอคอนด้านล่างเพื่อเริ่มต้น</p>
    </div>

    <div class="services-slider-container hero-slider">
      <div class="services-slider" id="servicesSlider">
        <% @services.each_with_index do |service, index| %>
          <a href="<%= index == 0 ? '/chat/provider' : "/chat/#{service.key}" %>" class="service-slide featured-slide">
            <div class="slide-glow"></div>
            <div class="service-icon"><%= service.icon %></div>
            <div class="service-info">
              <h3 class="service-name"><%= service.name(I18n.locale) %></h3>
              <span class="service-providers">
                <%= index==0?'10':service.providers_count %> <%= t("landing.services.providers") %>
              </span>
            </div>
            <div class="slide-action">
              <span>เริ่มเลย</span>
              <span class="action-arrow">→</span>
            </div>
          </a>
        <% end %>
      </div>

      <div class="slider-nav featured-nav">
        <button class="slider-btn prev" onclick="slideServices(-1)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="slider-btn next" onclick="slideServices(1)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="hero-services-footer">
      <div class="trust-badges">
        <div class="badge-item">
          <span class="badge-icon">✓</span>
          <span>ช่างมืออาชีพ</span>
        </div>
        <div class="badge-item">
          <span class="badge-icon">🛡️</span>
          <span>รับประกันงาน</span>
        </div>
        <div class="badge-item">
          <span class="badge-icon">⚡</span>
          <span>ตอบเร็ว</span>
        </div>
      </div>
    </div>
  </div>

  <script>
  function slideServices(direction) {
    const slider = document.getElementById('servicesSlider');
    const slides = slider.querySelectorAll('.service-slide');
    if (slides.length === 0) return;
    const slideWidth = slides[0].offsetWidth + 16;
    slider.scrollBy({ left: direction * slideWidth * 3, behavior: 'smooth' });
  }
  </script>
</section>
<!-- ═══════════════════════════════════════════════════════════════════════════
     SECTION 1: HERO - ดึงดูดความสนใจ สร้าง First Impression ที่ดี
     - Headline: ข้อความหลักที่สื่อสาร Value Proposition
     - Subheadline: อธิบายเพิ่มเติม
     - CTA Button: นำไปสู่การกระทำ
     - Badge: แสดงความน่าเชื่อถือ
═══════════════════════════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-badge">
    <span class="badge-icon">🚀</span>
    <span class="badge-text"><%= t("landing.hero.badge") %></span>
  </div>

  <h1 class="hero-headline">
    <%= t("landing.hero.headline") %>
  </h1>

  <p class="hero-subheadline">
    <%= t("landing.hero.subheadline") %>
  </p>

  <div class="hero-actions">
    <a href="https://lin.ee/PTfm8E1" class="btn btn-primary">
      <span>💬</span>
      <%= t("landing.hero.cta_primary") %>
    </a>
    <a href="#how-it-works" class="btn btn-secondary">
      <%= t("landing.hero.cta_secondary") %>
    </a>
  </div>

  <div class="hero-stats">
    <div class="stat">
      <span class="stat-value">10K+</span>
      <span class="stat-label"><%= t("landing.hero.stat1") %></span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-value">500+</span>
      <span class="stat-label"><%= t("landing.hero.stat2") %></span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-value">4.9</span>
      <span class="stat-label"><%= t("landing.hero.stat3") %></span>
    </div>
  </div>
</section>

