<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     RESPONSIVE TYPOGRAPHY & BASE STYLES
     Mobile-first approach: base styles สำหรับ mobile ก่อน
  �═══════════════════════════════════════════════════════════════════════════ */
  .landing-page {
    --primary: #1A1814;
    --accent: #C8A84B;
    --accent-light: #E8C96B;
    --bg: #FFFFFF;
    --bg-secondary: #F8F7F5;
    --bg-card: #FFFFFF;
    --text: #1A1814;
    --text-secondary: #6B6B6B;
    --text-muted: #9CA3AF;
    --border: #E5E5E3;
    --success: #22C55E;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
    --shadow: 0 4px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 12px 32px rgba(0,0,0,0.12);
    --radius: 16px;
    --radius-sm: 8px;
    --radius-lg: 24px;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     HERO SECTION STYLES
  �═══════════════════════════════════════════════════════════════════════════ */
  .hero {
    padding: 48px 20px 64px;
    text-align: center;
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg) 100%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 20px;
    box-shadow: var(--shadow-sm);
  }

  .hero-badge .badge-icon { font-size: 0.875rem; }

  .hero-headline {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--text);
  }

  .hero-headline span { color: var(--accent); }

  .hero-subheadline {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 320px;
    margin: 0 auto 24px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: var(--radius);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--primary);
    box-shadow: 0 4px 12px rgba(200, 168, 75, 0.3);
  }

  .btn-primary:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(200, 168, 75, 0.4);
  }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--bg-secondary);
    border-color: var(--text-secondary);
  }

  .btn-outline {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .btn-outline:hover {
    background: var(--accent);
    color: var(--primary);
  }

  .btn-cta {
    background: linear-gradient(135deg, var(--accent), var(--accent-light));
    color: var(--primary);
    font-size: 1.125rem;
    padding: 16px 32px;
    box-shadow: 0 6px 20px rgba(200, 168, 75, 0.4);
  }

  .btn-cta:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 28px rgba(200, 168, 75, 0.5);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: var(--bg-card);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
  }

  .stat { text-align: center; }

  .stat-value {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     SECTION HEADER STYLES (Shared)
  �═══════════════════════════════════════════════════════════════════════════ */
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-tag {
    display: inline-block;
    background: var(--accent);
    color: var(--primary);
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     FEATURES SECTION STYLES
  �═══════════════════════════════════════════════════════════════════════════ */
  .features {
    padding: 64px 20px;
    background: var(--bg);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px;
    text-align: center;
    transition: all 0.2s ease;
  }

  .feature-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 8px;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     HOW IT WORKS SECTION STYLES
  �═══════════════════════════════════════════════════════════════════════════ */
  .how-it-works {
    padding: 64px 20px;
    background: var(--bg-secondary);
  }

  .steps {
    max-width: 400px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: 20px;
    padding: 20px 0;
  }

  .step-number {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: var(--accent);
    color: var(--primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    box-shadow: 0 4px 12px rgba(200, 168, 75, 0.3);
  }

  .step-content { flex: 1; }

  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .step-connector {
    width: 2px;
    height: 24px;
    background: var(--border);
    margin-left: 23px;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     SERVICES SECTION STYLES
  �═══════════════════════════════════════════════════════════════════════════ */
  .services-showcase {
    padding: 64px 20px;
    background: var(--bg);
  }

  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .service-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s ease;
