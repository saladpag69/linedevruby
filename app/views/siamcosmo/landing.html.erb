<style>
  .landing-container {
    --hero-bg: #0a1628;
    --hero-overlay: linear-gradient(135deg, #0a1628 0%, #1a3a5c 50%, #0a1628 100%);
    --card-bg: var(--bg-secondary);
    --success: #22c55e;
    --success-dark: #16a34a;

    min-height: 100vh;
    background: var(--bg);
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 20px 60px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
    z-index: 0;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 600px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 8px 16px;
    border-radius: 50px;
    margin-bottom: 24px;
    backdrop-filter: blur(10px);
  }

  .badge-icon { font-size: 1.25rem; }
  .badge-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
  }

  .hero-headline {
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 20px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  /* Search */
  .search-container {
    margin-bottom: 24px;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 16px;
    padding: 6px 6px 6px 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .search-icon {
    color: #6b7280;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 12px;
    font-size: 1rem;
    background: transparent;
    color: #1f2937;
  }

  .search-input::placeholder {
    color: #9ca3af;
  }

  .search-btn {
    background: var(--accent);
    color: var(--primary);
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .search-btn:hover {
    background: #e5c76b;
    transform: scale(1.02);
  }

  /* Quick Categories */
  .quick-categories {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 32px;
  }

  .category-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    backdrop-filter: blur(10px);
  }

  .category-chip:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .chip-icon { font-size: 1.125rem; }

  /* CTA Buttons */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 40px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--primary);
  }

  .btn-primary:hover {
    background: #e5c76b;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(200, 168, 75, 0.4);
  }

  .btn-success {
    background: var(--success);
    color: #fff;
  }

  .btn-success:hover {
    background: var(--success-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(34, 197, 94, 0.4);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--border);
    color: var(--text);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-white {
    background: #fff;
    color: var(--hero-bg);
  }

  .btn-white:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
  }

  .btn-sm {
    padding: 8px 16px;
    font-size: 0.875rem;
  }

  .btn-lg {
    padding: 16px 32px;
    font-size: 1.125rem;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.2);
  }

  /* Sections */
  .section {
    padding: 60px 20px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .section-tag {
    display: inline-block;
    background: rgba(200, 168, 75, 0.1);
    color: var(--accent);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
  }

  /* Services Grid */
  .services-section {
    background: var(--bg);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 600px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 900px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
      max-width: 900px;
    }
  }

  .service-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: var(--card, var(--bg-secondary));
    border: 1px solid var(--border);
    border-radius: 16px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
  }

  .service-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .service-icon {
    font-size: 2rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    border-radius: 12px;
    flex-shrink: 0;
  }

  .service-content { flex: 1; min-width: 0; }

  .service-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .service-providers {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .service-arrow {
    color: var(--text-secondary);
    font-size: 1.25rem;
  }

  /* Shops */
  .shops-section {
    background: var(--bg-secondary);
  }

  .shops-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 16px;
    margin: 0 -20px;
    padding-left: 20px;
    padding-right: 20px;
    scroll-snap-type: x mandatory;
  }

  .shops-scroll::-webkit-scrollbar {
    display: none;
  }

  .shop-card {
    flex-shrink: 0;
    width: 300px;
    background: var(--card, var(--bg));
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    scroll-snap-align: start;
  }

  .shop-header {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
  }

  .shop-logo {
    width: 48px;
    height: 48px;
    background: var(--bg-secondary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .shop-info { flex: 1; }

  .shop-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
  }

  .shop-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8125rem;
  }

  .stars { letter-spacing: -2px; }
  .rating-value { font-weight: 600; color: var(--text); }
  .reviews { color: var(--text-secondary); }

  .shop-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 12px;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .shop-services {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .service-tag {
    padding: 4px 10px;
    background: var(--bg-secondary);
    border-radius: 50px;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .shop-actions {
    display: flex;
    gap: 8px;
  }

  .shop-actions .btn {
    flex: 1;
  }

  /* How It Works */
  .how-section {
    background: var(--bg);
  }

  .steps-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 500px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .steps-container {
      flex-direction: row;
      max-width: 900px;
      gap: 16px;
    }
  }

  .step-card {
    text-align: center;
    padding: 24px 16px;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: var(--primary);
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .step-icon {
    font-size: 3rem;
    margin-bottom: 12px;
  }

  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 8px;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .step-connector {
    width: 2px;
    height: 40px;
    background: var(--border);
  }

  @media (min-width: 768px) {
    .step-connector {
      width: 60px;
      height: 2px;
      flex-shrink: 0;
    }
  }

  /* CTA */
  .cta-section {
    padding: 60px 20px 100px;
    background: var(--bg-secondary);
  }

  .cta-card {
    text-align: center;
    padding: 48px 24px;
    background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 100%);
    border-radius: 24px;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }

  .cta-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .hero-section {
      padding: 100px 40px 80px;
    }

    .hero-headline {
      font-size: 3.5rem;
    }

    .hero-subtitle {
      font-size: 1.25rem;
    }

    .section {
      padding: 80px 40px;
    }

    .section-title {
      font-size: 2.25rem;
    }

    .cta-card {
      padding: 64px 48px;
    }

    .cta-title {
      font-size: 2.25rem;
    }
  }
</style>

<script nonce="<%= request.content_security_policy_nonce %>">
  document.querySelector('.search-btn').addEventListener('click', function() {
    const query = document.querySelector('.search-input').value;
    if (query.trim()) {
      window.location.href = '/chat?search=' + encodeURIComponent(query);
    }
  });

  document.querySelector('.search-input').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      document.querySelector('.search-btn').click();
    }
  });
</script>
