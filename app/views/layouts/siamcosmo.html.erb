<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="SiamCosmo">
  <meta name="mobile-web-app-capable" content="yes">
  <title>SiamCosmo - <%= content_for(:title) || t("siamcosmo") %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= yield :head %>
</head>

<body>
  <div class="app-container">
    <header class="header">
      <div class="header-left">
        <a href="/" class="logo">Siam<span>Cosmo</span></a>
      </div>
      <div class="header-right">
        <div class="lang-toggle">
          <button class="lang-btn <%= 'active' if I18n.locale == :th %>" data-lang="th">TH</button>
          <button class="lang-btn <%= 'active' if I18n.locale == :en %>" data-lang="en">EN</button>
          <button class="lang-btn <%= 'active' if I18n.locale == :zh %>" data-lang="zh">ZH</button>
        </div>
        <button class="icon-btn" data-theme-toggle>🌓</button>
        <!--<% if user_signed_in? %>
          <span class="user-name"><%= current_user.username || current_user.email %></span>
          <%= button_to "ออก", destroy_user_session_path, method: :delete, class: "icon-btn", title: "Logout" %>
        <% else %>
          <a href="/users/sign_in" class="icon-btn">👤</a>
        <% end %>-->
      </div>
    </header>

    <main class="main">
      <%= yield %>
    </main>

    <nav class="footer-nav">
      <a href="/" class="nav-item <%= 'active' if current_page?('/') %>">
        <span class="nav-icon">🏠</span>
        <span><%= t("home") %></span>
      </a>
      <a href="/calculator" class="nav-item <%= 'active' if request.path.start_with?('/calculator') %>">
        <span class="nav-icon">🧮</span>
        <span>คำนวณราคา</span>
      </a>
      <a href="/chat/contractor" class="nav-item <%= 'active' if request.path.start_with?('/chat') %>">
        <span class="nav-icon">💬</span>
        <span>Chat</span>
      </a>
    </nav>
  </div>

  <script nonce="<%= request.content_security_policy_nonce %>">
    // Language Toggle
    document.querySelectorAll('[data-lang]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        window.location.href = '/set_language/' + this.dataset.lang;
      });
    });

    // Theme Toggle
    var themeToggle = document.querySelector('[data-theme-toggle]');
    if (themeToggle) {
      themeToggle.addEventListener('click', function() {
        var html = document.documentElement;
        var current = html.getAttribute('data-theme');
        var themes = ['light', 'dark', 'system'];
        var currentIndex = themes.indexOf(current || 'light');
        var nextIndex = (currentIndex + 1) % themes.length;
        var nextTheme = themes[nextIndex];

        html.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
      });
    }

    // Load saved theme
    var savedTheme = localStorage.getItem('theme');
    if (savedTheme) {
      document.documentElement.setAttribute('data-theme', savedTheme);
    }
  </script>
</body>
</html>
