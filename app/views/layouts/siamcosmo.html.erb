<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="SiamCosmo">
  <meta name="mobile-web-app-capable" content="yes">
  <title>SiamCosmo - <%= content_for(:title) || t("siamcosmo") %></title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <%= yield :head %>

  <style>
    :root {
      --primary: #1A1814;
      --accent: #C8A84B;
      --bg: #FFFFFF;
      --bg-secondary: #F5F5F4;
      --text: #1A1814;
      --text-secondary: #6B6B6B;
      --border: #E5E5E3;
      --success: #22C55E;
      --error: #EF4444;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
      --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      --radius: 12px;
    }

    [data-theme="dark"] {
      --bg: #1A1814;
      --bg-secondary: #2D2A26;
      --text: #F5F5F4;
      --text-secondary: #A1A1A1;
      --border: #3D3A36;
    }

    [data-theme="system"] {
      color-scheme: light dark;
      --bg: #FFFFFF;
      --bg-secondary: #F5F5F4;
      --text: #1A1814;
      --text-secondary: #6B6B6B;
      --border: #E5E5E3;
    }

    @media (prefers-color-scheme: dark) {
      [data-theme="system"] {
        --bg: #1A1814;
        --bg-secondary: #2D2A26;
        --text: #F5F5F4;
        --text-secondary: #A1A1A1;
        --border: #3D3A36;
      }
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'IBM Plex Sans Thai', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    .app-container {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100vh;
      background: var(--bg);
      box-shadow: var(--shadow);
    }

    /* Tablet */
    @media (min-width: 481px) and (max-width: 768px) {
      .app-container {
        max-width: 100%;
      }
    }

    /* PC */
    @media (min-width: 769px) {
      .app-container {
        max-width: 1200px;
        margin: 24px auto;
        min-height: calc(100vh - 48px);
        border-radius: 16px;
        border: 1px solid var(--border);
      }
      
      .main {
        max-width: 960px;
        margin: 0 auto;
      }
    }

    /* Desktop XL */
    @media (min-width: 1200px) {
      .app-container {
        max-width: 1400px;
      }
    }

    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .logo {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--primary);
    }

    .logo span { color: var(--accent); }

    .header-right {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .icon-btn {
      width: 36px;
      height: 36px;
      border: none;
      background: var(--bg-secondary);
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      color: var(--text);
      transition: background 0.2s;
    }

    .icon-btn:hover {
      background: var(--border);
    }

    .lang-toggle {
      display: flex;
      background: var(--bg-secondary);
      border-radius: 8px;
      padding: 2px;
    }

    .lang-btn {
      padding: 4px 8px;
      border: none;
      background: transparent;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      border-radius: 6px;
      color: var(--text-secondary);
      transition: all 0.2s;
    }

    .lang-btn.active {
      background: var(--bg);
      color: var(--accent);
      box-shadow: var(--shadow-sm);
    }

    .main {
      padding: 16px;
      padding-bottom: 80px;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem;
      padding: 8px 0;
      cursor: pointer;
    }

    .back-btn:hover {
      color: var(--text);
    }

    .footer-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      max-width: 480px;
      margin: 0 auto;
      background: var(--bg);
      border-top: 1px solid var(--border);
      display: flex;
      padding: 8px 16px;
      padding-bottom: env(safe-area-inset-bottom, 8px);
      z-index: 100;
    }
    
    /* Hide footer nav on PC */
    @media (min-width: 769px) {
      .footer-nav {
        display: none;
      }
      
      .main {
        padding-bottom: 24px;
      }
    }

    .nav-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 8px;
      text-decoration: none;
      color: var(--text-secondary);
      font-size: 0.75rem;
      transition: color 0.2s;
    }

    .nav-item.active {
      color: var(--accent);
    }

    .nav-item:hover {
      color: var(--text);
    }

    .nav-icon {
      font-size: 1.25rem;
    }
  </style>
</head>

<body>
  <div class="app-container">
    <header class="header">
      <div class="header-left">
        <a href="/" class="logo">Siam<span>Cosmo</span></a>
      </div>
      <div class="header-right">
        <div class="lang-toggle">
          <button class="lang-btn <%= 'active' if I18n.locale == :th %>" data-lang="th">TH</button>
          <button class="lang-btn <%= 'active' if I18n.locale == :en %>" data-lang="en">EN</button>
          <button class="lang-btn <%= 'active' if I18n.locale == :zh %>" data-lang="zh">ZH</button>
        </div>
        <button class="icon-btn" data-theme-toggle>🌓</button>
        <a href="/login" class="icon-btn">👤</a>
      </div>
    </header>

    <main class="main">
      <%= yield %>
    </main>

    <nav class="footer-nav">
      <a href="/" class="nav-item <%= 'active' if current_page?('/') %>">
        <span class="nav-icon">🏠</span>
        <span><%= t("home") %></span>
      </a>
      <a href="/services" class="nav-item">
        <span class="nav-icon">📋</span>
        <span><%= t("services") %></span>
      </a>
      <a href="/chat" class="nav-item">
        <span class="nav-icon">💬</span>
        <span>Chat</span>
      </a>
      <a href="/profile" class="nav-item">
        <span class="nav-icon">👤</span>
        <span><%= t("profile") %></span>
      </a>
    </nav>
  </div>

  <script>
    // Fetch Baansiam prices on page load
    (async function() {
      try {
        const res = await fetch('/api/prices');
        const data = await res.json();
        window.siamCosmoPrices = data;
        console.log('Prices loaded:', window.siamCosmoPrices?.length || 0, 'items');
      } catch (e) {
        console.error('Failed to load prices:', e);
        window.siamCosmoPrices = { error: true };
      }
    })();

    // Theme Toggle
    const themeToggle = document.querySelector('[data-theme-toggle]');
    const html = document.documentElement;
    
    function setTheme(theme) {
      if (theme === 'system') {
        html.removeAttribute('data-theme');
        localStorage.removeItem('theme');
      } else {
        html.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
      }
    }

    // Load saved theme
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) setTheme(savedTheme);

    themeToggle?.addEventListener('click', () => {
      const current = html.getAttribute('data-theme') || 'system';
      setTheme(current === 'dark' ? 'light' : 'dark');
    });

    // Language Toggle
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang;
        window.location.href = `/set_language?locale=${lang}`;
      });
    });
  </script>
</body>
</html>