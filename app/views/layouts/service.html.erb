<!DOCTYPE html>
<html lang="<%= @lang %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= @service[:title] %> - SIAMCOSMO</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-primary: <%= @color[:bg] %>;
    --bg-card: <%= @color[:bg_card] %>;
    --primary: <%= @color[:primary] %>;
    --secondary: <%= @color[:secondary] %>;
    --accent: <%= @color[:accent] %>;
    --text: <%= @color[:text] %>;
    --text-secondary: <%= @color[:text_secondary] %>;
    --white: #FFFFFF;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
    --shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
    --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
    --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    --radius: 16px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: <%= @lang == 'th' ? "'Kanit'" : "'Inter'" %>, -apple-system, sans-serif;
    background: var(--bg-primary);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }

  .header {
    background: var(--white);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--primary);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
  }

  .logo-text span {
    color: var(--primary);
  }

  .lang-switcher {
    display: flex;
    gap: 0.5rem;
  }

  .lang-btn {
    padding: 6px 12px;
    border: none;
    background: var(--bg-primary);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    border-radius: 6px;
    color: var(--text-secondary);
    transition: all 0.2s;
    text-decoration: none;
  }

  .lang-btn:hover {
    color: var(--primary);
  }

  .lang-btn.active {
    background: var(--primary);
    color: white;
  }

  .hero {
    background: var(--white);
    padding: 3rem 2rem;
    text-align: center;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .hero-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    margin: 0 auto 1.5rem;
  }

  .hero h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .content {
    padding: 3rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .feature-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    border: 1px solid rgba(0,0,0,0.05);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
    color: white;
    margin-top: 2rem;
  }

  .cta-box h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .cta-box p {
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .cta-btn {
    display: inline-block;
    background: white;
    color: var(--primary);
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .footer {
    background: var(--white);
    border-top: 1px solid rgba(0,0,0,0.05);
    padding: 2rem;
    text-align: center;
  }

  .footer a {
    color: var(--primary);
    text-decoration: none;
  }

  .footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-wrap: wrap;
    }
  }
</style>
</head>
<body>

<header class="header">
  <div class="header-inner">
    <a href="/" class="back-link">← <%= @lang == 'th' ? 'กลับหน้าแรก' : 'Back to Home' %></a>

    <a href="/" class="logo">
      <div class="logo-icon">👩‍🚀</div>
      <div class="logo-text">SIAM<span>COSMO</span></div>
    </a>

    <div class="lang-switcher">
      <a href="/set_language?lang=th" class="lang-btn <%= 'active' if @lang == 'th' %>">TH</a>
      <a href="/set_language?lang=en" class="lang-btn <%= 'active' if @lang == 'en' %>">EN</a>
    </div>
  </div>
</header>

<section class="hero">
  <div class="hero-icon"><%= @service[:icon] %></div>
  <h1><%= @service[:title] %></h1>
  <p><%= @service[:description] %></p>
</section>

<section class="content">
  <h2 class="section-title"><%= @lang == 'th' ? 'คุณสมบัติ' : 'Features' %></h2>

  <div class="features-grid">
    <% @service[:features].each do |feature| %>
      <div class="feature-card">
        <h3>✓ <%= feature %></h3>
      </div>
    <% end %>
  </div>

  <div class="cta-box">
    <h3><%= @service[:cta] %></h3>
    <p><%= @lang == 'th' ? 'ติดต่อเราเพื่อเริ่มใช้บริการ' : 'Contact us to get started' %></p>
    <a href="/" class="cta-btn">💬 <%= @lang == 'th' ? 'แชท LINE' : 'LINE Chat' %></a>
  </div>
</section>

<footer class="footer">
  <a href="/">← <%= @lang == 'th' ? 'กลับหน้าแรก' : 'Back to Home' %></a>
</footer>

<%= render 'shared/mindmap_hub' %>

</body>
</html>
