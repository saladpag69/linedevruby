<%- if resource.errors.any? %>
  <div class="alert alert-error">
    <ul>
      <%- resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<style>
  .alert {
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 16px;
  }
  .alert-error {
    background: #FEE2E2;
    color: #DC2626;
    border: 1px solid #FECACA;
  }
  .alert ul {
    margin: 0;
    padding-left: 16px;
  }
</style>