<%- if controller_name != 'sessions' %>
  <%= link_to "เข้าสู่ระบบ", new_session_path(resource_name) %><br />
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "สมัครสมาชิก", new_registration_path(resource_name) %><br />
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "ลืมรหัสผ่าน?", new_password_path(resource_name) %><br />
<% end %>