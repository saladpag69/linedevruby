<style>
  .product-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
    font-family: "Inter", "Sarabun", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .product-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .product-header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem;
  }

  .search-bar {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .search-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: min(480px, 100%);
  }

  .search-actions form {
    display: flex;
    gap: 0.75rem;
    width: 100%;
  }

  .search-input {
    flex: 1;
    border-radius: 999px;
    border: 1px solid #d0d5dd;
    padding: 0.6rem 1rem;
    font-size: 1rem;
  }

  .search-button {
    border: none;
    border-radius: 999px;
    padding: 0.55rem 1.4rem;
    background: linear-gradient(120deg, #ec4899, #8b5cf6);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .search-button:hover {
    opacity: 0.9;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    border-radius: 1rem;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 18px 35px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 45px rgba(0, 0, 0, 0.15);
  }

  .product-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .product-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .product-name {
    font-weight: 600;
    font-size: 1.1rem;
  }

  .product-meta {
    font-size: 0.95rem;
    color: #50505a;
  }

  .product-footer {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-top: 1px solid #f0f2f5;
  }

  .cta-button {
    border: none;
    border-radius: 999px;
    padding: 0.45rem 1.1rem;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff;
    font-size: 0.9rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.85;
  }

  .ai.chat.message {
    margin: 2.5rem auto 2rem;
    max-width: 760px;
    padding: 1.5rem 1.75rem;
    border-radius: 24px;
    background: linear-gradient(135deg, #fff7ed 0%, #eef7ff 45%, #f7f0ff 100%);
    border: 1px solid rgba(148, 163, 184, 0.35);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    position: relative;
    overflow: hidden;
  }

  .ai.chat.message::before {
    content: "ผู้ช่วย AI";
    position: absolute;
    top: 16px;
    right: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #0f172a;
    background: rgba(255, 255, 255, 0.85);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }

  .ai.chat.message::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 15% 20%, rgba(34, 197, 94, 0.12), transparent 45%),
      radial-gradient(circle at 85% 0%, rgba(14, 165, 233, 0.15), transparent 45%),
      radial-gradient(circle at 80% 85%, rgba(251, 146, 60, 0.12), transparent 50%);
    pointer-events: none;
  }

  .ai.chat.message .message-content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    max-height: 320px;
    overflow-y: auto;
    padding-right: 0.25rem;
  }

  .ai.chat.message .message-content p {
    margin: 0;
    padding: 0.75rem 1rem;
    border-radius: 18px;
    max-width: 80%;
    background: rgba(255, 255, 255, 0.9);
    color: #0f172a;
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.08);
    line-height: 1.5;
  }

  .ai.chat.message .message-content .chat-line.user {
    align-self: flex-end;
    background: linear-gradient(135deg, #0ea5e9, #22c55e);
    color: #ffffff;
  }

  .ai.chat.message .message-content .chat-line.ai {
    align-self: flex-start;
  }

  .ai.chat.message .message-content .chat-line.error {
    align-self: flex-start;
    background: #fee2e2;
    color: #b91c1c;
  }
</style>

