  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const supplierButton = document.getElementById("supplier-line-button");
//      if (!supplierButton) return;
      const clearButton = document.getElementById("clear-ai-chat");

      const csrfMeta = document.querySelector('meta[name="csrf-token"]');
      const csrfToken = csrfMeta ? csrfMeta.getAttribute("content") : "";
      const searchInput = document.querySelector(".search-input");
      // const chatContent = document.querySelector(".ai.chat.message .message-content");
      // const buttonLabel = supplierButton.textContent;
      const chatContent = document.querySelector(".ai-chat-message .message-content") || document.querySelector(".ai.chat.message .message-content");
      if (!chatContent) return;
      const initialChatContent = chatContent.innerHTML;
      const buttonLabel = supplierButton ? supplierButton.textContent : "";


      const appendChatLine = (text, role) => {
        if (!chatContent || !text) return;
        const line = document.createElement("p");
        line.className = `chat-line ${role}`;
        line.textContent = text;
        chatContent.appendChild(line);
      };

      if (clearButton) {
        clearButton.addEventListener("click", function() {
          chatContent.innerHTML = initialChatContent;
        });
      }

      if (!supplierButton) return;


      supplierButton.addEventListener("click", async function() {
        if (supplierButton.disabled) return;

        supplierButton.disabled = true;
        supplierButton.textContent = "กำลังส่ง...";

        try {
          const query = searchInput ? searchInput.value.trim() : "";
          if (query) {
            appendChatLine(query, "user");
          }

          const response = await fetch(supplierButton.dataset.endpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrfToken,
              "Accept": "application/json"
            },
            body: JSON.stringify({ query: query })
          });

          let payload = {};
          try {
            payload = await response.json();
          } catch (error) {
            payload = {};
          }

          const responseText = payload.reply || payload.response || payload.message || (response.ok ? "ส่งข้อความเรียบร้อยแล้ว" : "ส่งข้อความไม่สำเร็จ");
          appendChatLine(responseText, "ai");
        } catch (error) {
          appendChatLine(`ส่งข้อความไม่สำเร็จ โปรดลองอีกครั้ง ${error}`, "error");
        } finally {
          supplierButton.disabled = false;
          supplierButton.textContent = buttonLabel;
        }
      });
    });
  </script>
</div>
