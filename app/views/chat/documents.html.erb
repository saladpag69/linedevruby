<% content_for :title, "เอกสารการก่อสร้าง" %>

<div class="documents-page">
  <div class="documents-header">
    <h1>📁 เอกสารการก่อสร้าง</h1>
    <p>รวบรวมเอกสารที่จำเป็นสำหรับงานก่อสร้างและบริการต่างๆ</p>
  </div>

  <div class="categories-grid">
    <% @categories.each do |category| %>
      <section class="category-section">
        <div class="category-header">
          <span class="category-icon"><%= category[:icon] %></span>
          <div class="category-title">
            <h2><%= category[:title] %></h2>
            <p><%= category[:description] %></p>
          </div>
        </div>

        <div class="documents-list">
          <% category[:documents].each do |doc| %>
            <a href="<%= doc[:url] %>" class="document-card">
              <div class="doc-icon">📄</div>
              <div class="doc-info">
                <h3><%= doc[:name] %></h3>
                <p><%= doc[:description] %></p>
              </div>
              <div class="doc-arrow">→</div>
            </a>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>

<style>
  .documents-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
    font-family: "Inter", "Sarabun", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .documents-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .documents-header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem;
    color: #1f2937;
  }

  .documents-header p {
    font-size: 1.1rem;
    color: #6b7280;
    margin: 0;
  }

  .categories-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .category-section {
    background: #fff;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    border-bottom: 1px solid #e2e8f0;
  }

  .category-icon {
    font-size: 2.5rem;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .category-title h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: #1f2937;
  }

  .category-title p {
    font-size: 0.9rem;
    color: #6b7280;
    margin: 0;
  }

  .documents-list {
    padding: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .document-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .document-card:hover {
    background: #f1f5f9;
    transform: translateX(4px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .doc-icon {
    font-size: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 0.5rem;
    flex-shrink: 0;
  }

  .doc-info {
    flex: 1;
    min-width: 0;
  }

  .doc-info h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: #1f2937;
  }

  .doc-info p {
    font-size: 0.8rem;
    color: #6b7280;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .doc-arrow {
    font-size: 1.25rem;
    color: #9ca3af;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .documents-header h1 {
      font-size: 2rem;
    }

    .documents-list {
      grid-template-columns: 1fr;
    }

    .category-header {
      flex-direction: column;
      text-align: center;
    }
  }
</style>