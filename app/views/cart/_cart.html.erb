<div style="border:1px solid #ddd; border-radius:8px; padding:16px; margin-bottom:16px;">
  <div style="font-weight:bold; margin-bottom:8px;">
    👤 <%= cart.line_user_id %>
    <span style="color:#888; font-size:0.85em; margin-left:8px;">
      (<%= cart.cart_items.count %> รายการ)
    </span>
  </div>

  <% if cart.cart_items.empty? %>
    <p style="color:#aaa;">ตะกร้าว่างเปล่า</p>
  <% else %>
    <table style="width:100%; border-collapse:collapse;">
      <thead>
        <tr style="border-bottom:1px solid #eee; text-align:left;">
          <th style="padding:4px 8px;">สินค้า</th>
          <th style="padding:4px 8px; text-align:center;">จำนวน</th>
          <th style="padding:4px 8px; text-align:right;">ราคา/หน่วย</th>
          <th style="padding:4px 8px; text-align:right;">รวม</th>
        </tr>
      </thead>
      <tbody>
        <% cart.cart_items.each do |item| %>
          <tr style="border-bottom:1px solid #f5f5f5;">
            <td style="padding:4px 8px;"><%= item.product_name %></td>
            <td style="padding:4px 8px; text-align:center;"><%= item.quantity %> <%= item.unit %></td>
            <td style="padding:4px 8px; text-align:right;">฿<%= item.price %></td>
            <td style="padding:4px 8px; text-align:right;">฿<%= (item.price.to_f * item.quantity).round(2) %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr style="font-weight:bold;">
          <td colspan="3" style="padding:8px; text-align:right;">รวมทั้งหมด</td>
          <td style="padding:8px; text-align:right;">
            ฿<%= cart.cart_items.sum { |i| i.price.to_f * i.quantity }.round(2) %>
          </td>
        </tr>
      </tfoot>
    </table>
  <% end %>

  <div style="color:#aaa; font-size:0.8em; margin-top:8px;">
    สร้างเมื่อ <%= cart.created_at.strftime("%d/%m/%Y %H:%M") %>
    | หมดอายุ <%= cart.expires_at.strftime("%d/%m/%Y %H:%M") %>
  </div>

  <div style="margin-top:12px;">
    <%= link_to "← กลับไปเลือกสินค้า", aboutus_path, style: "display:inline-block; padding:6px 16px; border-radius:999px; background:linear-gradient(120deg,#4f46e5,#7c3aed); color:#fff; text-decoration:none; font-size:0.9rem;" %>
  </div>
</div>
