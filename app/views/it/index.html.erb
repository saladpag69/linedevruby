<!DOCTYPE html>
<html lang="<%= @lang %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= @service[:title] %> - SIAMCOSMO</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-primary: <%= @color[:bg] %>;
    --bg-card: <%= @color[:bg_card] %>;
    --primary: <%= @color[:primary] %>;
    --secondary: <%= @color[:secondary] %>;
    --text: <%= @color[:text] %>;
    --text-secondary: <%= @color[:text_secondary] %>;
    --white: #FFFFFF;
    --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    --radius: 16px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: <%= @lang == 'th' ? "'Kanit'" : "'Inter'" %>, sans-serif;
    background: var(--bg-primary);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }
  .header {
    background: var(--white);
    padding: 1rem 2rem;
    box-shadow: var(--shadow);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .back-link { color: var(--primary); text-decoration: none; font-weight: 500; }
  .hero {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    padding: 3rem 2rem;
    text-align: center;
    color: white;
  }
  .hero h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .hero p { opacity: 0.9; }
  .mindmap-center-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.2);
    border: 2px solid rgba(255,255,255,0.5);
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    color: white;
    text-decoration: none;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .mindmap-center-btn:hover {
    background: rgba(255,255,255,0.3);
    transform: scale(1.05);
  }
  .mindmap-center-btn span:first-child { font-size: 1.2rem; }
  .content {
    padding: 3rem 2rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .coming-soon {
    background: var(--white);
    border-radius: var(--radius);
    padding: 4rem 2rem;
    box-shadow: var(--shadow);
  }
  .coming-soon h2 { color: var(--primary); margin-bottom: 1rem; }
  .coming-soon p { color: var(--text-secondary); }
</style>
</head>
<body>

<header class="header">
  <div class="header-inner">
    <a href="/" class="back-link">← <%= @lang == 'th' ? 'กลับหน้าหลัก' : 'Back to Home' %></a>
    <a href="/" style="text-decoration: none; color: var(--primary); font-weight: 700;">👩‍🚀 SIAMCOSMO</a>
  </div>
</header>

<section class="hero">
  <h1><%= @service[:icon] %> <%= @service[:title] %></h1>
  <p><%= @service[:subtitle] %></p>
</section>

<section class="content">
  <div class="coming-soon">
    <h2>🚧 <%= @lang == 'th' ? 'กำลังพัฒนา' : 'Under Construction' %></h2>
    <p><%= @lang == 'th' ? 'บริการนี้กำลังอยู่ในขั้นตอนการพัฒนา' : 'This service is under development' %></p>
  </div>
</section>

</body>
</html>
