<% content_for :title, @service_type.name %>

<div class="calculator-header">
  <a href="<%= calculator_path %>" class="back-btn">
    ← กลับ
  </a>
  <div class="step-indicator">
    <span class="step completed">✓</span>
    <span class="step-line active"></span>
    <span class="step active">2</span>
    <span class="step-line"></span>
    <span class="step">3</span>
    <span class="step-line"></span>
    <span class="step">4</span>
  </div>
  <h2 class="step-title">ใส่ขนาดพื้นที่</h2>
  <p class="step-subtitle"><%= @service_type.icon %> <%= @service_type.name %></p>
</div>

<div class="input-form" data-controller="calculator" data-service-type="<%= @service_type.slug %>" data-labor-rate="<%= @service_type.labor_rate_per_sqm %>">
  <form action="<%= calculator_step3_path %>" method="POST" data-calculator-target="form">
    <input type="hidden" name="service_type_slug" value="<%= @service_type.slug %>">
    <%= csrf_meta_tags %>

    <div class="form-group">
      <label class="form-label">ความกว้าง (เมตร)</label>
      <input type="number"
             name="width"
             class="form-input"
             placeholder="เช่น 6"
             step="0.01"
             min="0.1"
             required
             data-calculator-target="width"
             data-action="input->calculator#calculate">
    </div>

    <div class="form-group">
      <label class="form-label">ความยาว (เมตร)</label>
      <input type="number"
             name="length"
             class="form-input"
             placeholder="เช่น 8"
             step="0.01"
             min="0.1"
             required
             data-calculator-target="length"
             data-action="input->calculator#calculate">
    </div>

    <% if @service_type.slug == "concrete_floor" || @service_type.slug == "brick_wall" %>
      <div class="form-group">
        <label class="form-label">ความหนา (เมตร)</label>
        <input type="number"
               name="thickness"
               class="form-input"
               placeholder="เช่น 0.10"
               step="0.01"
               min="0.01"
               value="0.10"
               data-calculator-target="thickness"
               data-action="input->calculator#calculate">
        <span class="form-hint">ความหนามาตรฐาน 10 ซม. = 0.10 เมตร</span>
      </div>
    <% elsif @service_type.slug == "paint_wall" %>
      <div class="form-group">
        <label class="form-label">ความสูง (เมตร)</label>
        <input type="number"
               name="height"
               class="form-input"
               placeholder="เช่น 2.5"
               step="0.01"
               min="0.1"
               value="2.5"
               data-calculator-target="height"
               data-action="input->calculator#calculate">
      </div>
    <% end %>

    <div class="preview-card" data-calculator-target="preview">
      <div class="preview-header">
        <span class="preview-icon">📐</span>
        <span class="preview-label">สูตรคำนวณ</span>
      </div>
      <div class="preview-formula" data-calculator-target="formula">
        กรุณาใส่ขนาดพื้นที่
      </div>
      <div class="preview-values" data-calculator-target="values">
        <div class="preview-item">
          <span class="preview-item-label">พื้นที่</span>
          <span class="preview-item-value" data-calculator-target="area">- ตร.ม.</span>
        </div>
        <div class="preview-item">
          <span class="preview-item-label">ปริมาตร</span>
          <span class="preview-item-value" data-calculator-target="volume">- ลบ.ม.</span>
        </div>
        <div class="preview-item">
          <span class="preview-item-label">ค่าแรง (โดยประมาณ)</span>
          <span class="preview-item-value" data-calculator-target="labor">฿0</span>
        </div>
      </div>
    </div>

    <!--<button type="submit" class="btn-primary" data-calculator-target="submitBtn" disabled>
      ถัดไป →
    </button>-->
  </form>
</div>

<style>
  .input-form {
    padding: 16px;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 6px;
  }

  .form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 1rem;
    background: var(--bg);
    color: var(--text);
    transition: border-color 0.2s;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .preview-card {
    background: var(--bg-secondary);
    border-radius: 14px;
    padding: 16px;
    margin: 24px 0;
    border: 0.5px solid var(--border);
  }

  .preview-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .preview-icon {
    font-size: 1.25rem;
  }

  .preview-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .preview-formula {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .preview-values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .preview-item {
    text-align: center;
  }

  .preview-item-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 4px;
  }

  .preview-item-value {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
  }

  .btn-primary {
    width: 100%;
    padding: 14px 24px;
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-primary:disabled {
    background: var(--text-secondary);
    cursor: not-allowed;
  }
</style>
