<!DOCTYPE html>
<html lang="<%= @lang %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= @t["calculator"] || "เครื่องคำนวณวัสดุ" %> - SIAMCOSMO</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #1A1814;
  --accent: #C8A84B;
  --bg: #FFFFFF;
  --bg-secondary: #F5F5F4;
  --text: #1A1814;
  --text-secondary: #6B6B6B;
  --border: #E5E5E3;
  --success: #22C55E;
  --error: #EF4444;
  --radius: 12px;
  --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'IBM Plex Sans Thai', sans-serif;
  background: var(--bg-secondary);
  color: var(--text);
  line-height: 1.5;
  min-height: 100vh;
}
.header {
  background: var(--bg);
  padding: 1rem 1.5rem;
  box-shadow: var(--shadow);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header a { color: var(--primary); text-decoration: none; font-weight: 600; }
.hero {
  background: linear-gradient(135deg, var(--primary), var(--accent));
  padding: 2rem 1.5rem;
  text-align: center;
  color: white;
}
.hero h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
.hero p { opacity: 0.9; font-size: 0.9rem; }

.tabs {
  display: flex;
  gap: 8px;
  padding: 16px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-btn {
  flex: 1;
  padding: 12px 16px;
  border: 2px solid var(--border);
  background: var(--bg);
  color: var(--text-secondary);
  border-radius: var(--radius);
  cursor: pointer;
  font-weight: 600;
  font-size: 0.9rem;
  font-family: inherit;
  transition: all 0.2s;
}
.tab-btn.active {
  border-color: var(--accent);
  background: var(--accent);
  color: var(--primary);
}
.tab-content {
  display: none;
  padding: 16px;
}
.tab-content.active { display: block; }

.calc-section {
  background: var(--bg);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: var(--shadow);
}
.calc-section h3 {
  color: var(--primary);
  margin-bottom: 12px;
  font-size: 1rem;
  padding-bottom: 8px;
  border-bottom: 2px solid var(--accent);
}

.input-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 768px) {
  .input-row { grid-template-columns: repeat(4, 1fr); }
}
.input-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.input-group label {
  font-size: 0.8rem;
  color: var(--text-secondary);
  font-weight: 500;
}
.input-group input {
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 1rem;
  font-family: inherit;
  background: var(--bg);
  color: var(--text);
}
.input-group input:focus {
  outline: none;
  border-color: var(--accent);
}

.results-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 768px) { .results-grid { grid-template-columns: repeat(5, 1fr); } }
.result-card {
  background: var(--bg-secondary);
  padding: 12px;
  border-radius: 8px;
  text-align: center;
}
.result-card .shape-icon { font-size: 1.5rem; margin-bottom: 4px; }
.result-card .shape-name { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 4px; }
.result-card .shape-value { font-size: 1.1rem; font-weight: 700; color: var(--accent); }

.job-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}
@media (min-width: 768px) { .job-buttons { grid-template-columns: repeat(4, 1fr); } }
.job-btn {
  padding: 12px;
  border: 2px solid var(--border);
  background: var(--bg);
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.85rem;
  font-family: inherit;
  transition: all 0.2s;
  color: var(--text);
}
.job-btn.active {
  border-color: var(--accent);
  background: var(--accent);
  color: var(--primary);
}

.material-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}
.material-table th, .material-table td {
  padding: 10px 8px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}
.material-table th {
  background: var(--bg-secondary);
  font-weight: 600;
  color: var(--text-secondary);
}
.material-table td { font-size: 0.85rem; }
.material-table .num { text-align: right; font-family: monospace; }
.material-table .total-row {
  background: var(--accent);
  color: var(--primary);
  font-weight: 700;
}
.material-table .total-row td { border: none; }

.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}
.action-btn {
  flex: 1;
  padding: 12px;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9rem;
  font-family: inherit;
  cursor: pointer;
  text-align: center;
}
.btn-pdf { background: var(--error); color: white; }
.btn-line { background: #06C755; color: white; }

.chat-messages {
  max-height: 400px;
  overflow-y: auto;
  padding: 12px;
  background: var(--bg-secondary);
  border-radius: 8px;
  margin-bottom: 12px;
}
.message {
  max-width: 80%;
  padding: 10px 14px;
  border-radius: 12px;
  margin-bottom: 8px;
  font-size: 0.9rem;
}
.message.bot {
  background: var(--bg);
  align-self: flex-start;
}
.message.user {
  background: var(--accent);
  color: var(--primary);
  margin-left: auto;
}
.chat-input {
  display: flex;
  gap: 8px;
}
.chat-input input {
  flex: 1;
  padding: 12px;
  border: 1px solid var(--border);
  border-radius: 24px;
  font-family: inherit;
  font-size: 0.9rem;
}
.chat-input button {
  padding: 12px 20px;
  background: var(--accent);
  color: var(--primary);
  border: none;
  border-radius: 24px;
  font-weight: 600;
  cursor: pointer;
}

.calculator-form {
  background: var(--bg-secondary);
  padding: 16px;
  border-radius: 12px;
  margin: 8px 0;
}
.shape-selector {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}
.shape-btn {
  width: 40px;
  height: 40px;
  border: 2px solid var(--border);
  background: var(--bg);
  border-radius: 8px;
  cursor: pointer;
  font-size: 1.25rem;
}
.shape-btn.active {
  border-color: var(--accent);
  background: var(--accent);
}
.shape-inputs {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}
.shape-inputs input {
  flex: 1;
  padding: 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg);
}
.calc-btn {
  width: 100%;
  padding: 12px;
  background: var(--accent);
  color: var(--primary);
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
}
.calc-result {
  margin-top: 12px;
  font-weight: 600;
  color: var(--accent);
  text-align: center;
}
</style>
</head>
<body>

<header class="header">
  <!--<a href="/">← กลับ</a>
  <a href="/">👩‍🚀 SiamCosmo</a>-->
</header>

<section class="hero">
  <h1>🧮 เครื่องคำนวณวัสดุ</h1>
  <p>คำนวณพื้นที่ ปริมาตร และประมาณราคาวัสดุ</p>
</section>

<div class="tabs">
  <button class="tab-btn active" data-tab="calc">คำนวณพื้นที่</button>
  <button class="tab-btn" data-tab="ai">ถาม AI Bot</button>
</div>

<!-- Tab 1: คำนวณพื้นที่ -->
<div id="tab-calc" class="tab-content active">

  <!-- Section 1: Input พื้นฐาน -->
  <div class="calc-section">
    <h3>📐 ขนาดพื้นที่</h3>
    <div class="input-row">
      <div class="input-group">
        <label>กว้าง (ม.)</label>
        <input type="number" id="input-width" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>ยาว (ม.)</label>
        <input type="number" id="input-length" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>สูง (ม.)</label>
        <input type="number" id="input-height" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>หนา (ม.)</label>
        <input type="number" id="input-thickness" value="0.10" min="0" step="0.01">
      </div>
    </div>
  </div>

  <!-- Section 1: Output รูปทรง -->
  <div class="calc-section">
    <h3>📊 ผลลัพธ์พื้นที่และปริมาตร</h3>
    <div class="results-grid">
      <div class="result-card">
        <div class="shape-icon">⬜</div>
        <div class="shape-name">สี่เหลี่ยม</div>
        <div class="shape-value" id="res-rectangle">16 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">🔺</div>
        <div class="shape-name">สามเหลี่ยม</div>
        <div class="shape-value" id="res-triangle">8 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">🔻</div>
        <div class="shape-name">สี่เหลี่ยมคางหมู</div>
        <div class="shape-value" id="res-trapezoid">16 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">⭕</div>
        <div class="shape-name">วงกลม</div>
        <div class="shape-value" id="res-circle">12.57 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">📦</div>
        <div class="shape-name">ปริมาตร</div>
        <div class="shape-value" id="res-volume">1.60 ลบ.ม.</div>
      </div>
    </div>
  </div>

  <!-- Section 2: ประเภทงาน -->
  <div class="calc-section">
    <h3>🔨 เลือกประเภทงาน</h3>
    <div class="job-buttons">
      <button class="job-btn" data-job="concrete">เทพื้นคอนกรีต</button>
      <button class="job-btn" data-job="tile">ปูกระเบื้อง</button>
      <button class="job-btn" data-job="wood">ติดตั้งไม้ฝา</button>
      <button class="job-btn" data-job="paint">ทาสี</button>
    </div>
  </div>

  <!-- Paint extra inputs -->
  <div class="calc-section" id="paint-inputs" style="display: none;">
    <h3>🚪 หักพื้นที่เปิด (ไม่ทาสี)</h3>
    <div class="input-row">
      <div class="input-group">
        <label>พื้นที่ประตู (ตร.ม.)</label>
        <input type="number" id="paint-door" value="2.1" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>พื้นที่หน้าต่าง (ตร.ม.)</label>
        <input type="number" id="paint-window" value="1.5" min="0" step="0.01">
      </div>
    </div>
  </div>

  <!-- Section 3: รายการวัสดุ -->
  <div class="calc-section" id="materials-section" style="display: none;">
    <h3>📋 รายการวัสดุและราคา</h3>
    <table class="material-table">
      <thead>
        <tr>
          <th>วัสดุ</th>
          <th>ปริมาณ</th>
          <th>ราคา/หน่วย</th>
          <th>รวม</th>
        </tr>
      </thead>
      <tbody id="materials-body">
      </tbody>
      <tfoot>
        <tr class="total-row">
          <td colspan="3">ยอดรวม</td>
          <td id="total-price">0 บาท</td>
        </tr>
      </tfoot>
    </table>
    <div class="action-buttons">
      <button class="action-btn btn-pdf">📄 Download PDF</button>
      <button class="action-btn btn-line">💬 สั่งซื้อ LINE</button>
    </div>
  </div>

</div>

<!-- Tab 2: AI Bot -->
