<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>เครื่องคำนวณวัสดุ - SiamCosmo</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #1A1814;
  --accent: #C8A84B;
  --bg: #FFFFFF;
  --bg-secondary: #F5F5F4;
  --text: #1A1814;
  --text-secondary: #6B6B6B;
  --border: #E5E5E3;
  --success: #22C55E;
  --error: #EF4444;
  --radius: 12px;
  --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'IBM Plex Sans Thai', sans-serif;
  background: var(--bg-secondary);
  color: var(--text);
  line-height: 1.5;
  min-height: 100vh;
}
.header {
  background: var(--bg);
  padding: 1rem 1.5rem;
  box-shadow: var(--shadow);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header a { color: var(--primary); text-decoration: none; font-weight: 600; }
.hero {
  background: linear-gradient(135deg, var(--primary), var(--accent));
  padding: 1.5rem;
  text-align: center;
  color: white;
}
.hero h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
.hero p { opacity: 0.9; font-size: 0.9rem; }

.tabs {
  display: flex;
  gap: 8px;
  padding: 16px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-btn {
  flex: 1;
  padding: 12px 16px;
  border: 2px solid var(--border);
  background: var(--bg);
  color: var(--text-secondary);
  border-radius: var(--radius);
  cursor: pointer;
  font-weight: 600;
  font-size: 0.85rem;
  font-family: inherit;
  transition: all 0.2s;
}
.tab-btn.active {
  border-color: var(--accent);
  background: var(--accent);
  color: var(--primary);
}
.tab-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.tab-content { display: none; padding: 16px; }
.tab-content.active { display: block; }

.calc-section {
  background: var(--bg);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: var(--shadow);
}
.calc-section h3 {
  color: var(--primary);
  margin-bottom: 12px;
  font-size: 1rem;
  padding-bottom: 8px;
  border-bottom: 2px solid var(--accent);
}

.input-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 768px) { .input-row { grid-template-columns: repeat(4, 1fr); } }
.input-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.input-group label {
  font-size: 0.8rem;
  color: var(--text-secondary);
  font-weight: 500;
}
.input-group input, .input-group select {
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 1rem;
  font-family: inherit;
  background: var(--bg);
  color: var(--text);
}
.input-group input:focus, .input-group select:focus {
  outline: none;
  border-color: var(--accent);
}

.results-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 768px) { .results-grid { grid-template-columns: repeat(5, 1fr); } }
.result-card {
  background: var(--bg-secondary);
  padding: 12px;
  border-radius: 8px;
  text-align: center;
}
.result-card .shape-icon { font-size: 1.5rem; margin-bottom: 4px; }
.result-card .shape-name { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 4px; }
.result-card .shape-value { font-size: 1rem; font-weight: 700; color: var(--accent); }

.job-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}
@media (min-width: 768px) { .job-buttons { grid-template-columns: repeat(4, 1fr); } }
.job-btn {
  padding: 12px;
  border: 2px solid var(--border);
  background: var(--bg);
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.85rem;
  font-family: inherit;
  transition: all 0.2s;
  color: var(--text);
}
.job-btn.active {
  border-color: var(--accent);
  background: var(--accent);
  color: var(--primary);
}

.roof-input {
  display: none;
  margin-top: 12px;
  padding: 12px;
  background: var(--bg-secondary);
  border-radius: 8px;
}
.roof-input.show { display: block; }

.material-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}
.material-table th, .material-table td {
  padding: 10px 8px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}
.material-table th {
  background: var(--bg-secondary);
  font-weight: 600;
  color: var(--text-secondary);
}
.material-table td { font-size: 0.85rem; }
.material-table .num { text-align: right; font-family: monospace; }
.material-table .total-row {
  background: var(--accent);
  color: var(--primary);
  font-weight: 700;
}
.material-table .total-row td { border: none; }

.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}
.action-btn {
  flex: 1;
  padding: 12px;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9rem;
  font-family: inherit;
  cursor: pointer;
  text-align: center;
}
.btn-pdf { background: var(--error); color: white; }
.btn-line { background: #06C755; color: white; }

.empty-state {
  text-align: center;
  padding: 32px;
  color: var(--text-secondary);
}
</style>
</head>
<body>

<header class="header">
  <a href="/">← กลับ</a>
  <a href="/">👩‍🚀 SiamCosmo</a>
</header>

<section class="hero">
  <h1>🧮 เครื่องคำนวณวัสดุ</h1>
  <p>คำนวณพื้นที่ ปริมาตร และประมาณราคาวัสดุ</p>
</section>

<div class="tabs">
  <button class="tab-btn active" data-tab="area">คำนวณพื้นที่</button>
  <button class="tab-btn" data-tab="material">คำนวณตามประเภทวัสดุ</button>
  <button class="tab-btn" data-tab="custom" disabled>กำหนดเอง</button>
</div>

<!-- Tab 1: คำนวณพื้นที่/ปริมาตร -->
<div id="tab-area" class="tab-content active">
  <div class="calc-section">
    <h3>📐 ขนาดพื้นที่</h3>
    <div class="input-row">
      <div class="input-group">
        <label>กว้าง (ม.)</label>
        <input type="number" id="area-width" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>ยาว (ม.)</label>
        <input type="number" id="area-length" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>สูง/หนา (ม.)</label>
        <input type="number" id="area-height" value="0.15" min="0" step="0.01">
      </div>
    </div>
  </div>

  <div class="calc-section">
    <h3>📊 ผลลัพธ์</h3>
    <div class="results-grid">
      <div class="result-card">
        <div class="shape-icon">⬜</div>
        <div class="shape-name">สี่เหลี่ยม</div>
        <div class="shape-value" id="res-rectangle">16.00 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">🔺</div>
        <div class="shape-name">สามเหลี่ยม</div>
        <div class="shape-value" id="res-triangle">0.60 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">🔻</div>
        <div class="shape-name">สี่เหลี่ยมคางหมู</div>
        <div class="shape-value" id="res-trapezoid">0.60 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">⭕</div>
        <div class="shape-name">วงกลม</div>
        <div class="shape-value" id="res-circle">12.57 ตร.ม.</div>
      </div>
      <div class="result-card">
        <div class="shape-icon">📦</div>
        <div class="shape-name">ปริมาตร</div>
        <div class="shape-value" id="res-volume">0.24 ลบ.ม.</div>
      </div>
    </div>
  </div>
</div>

<!-- Tab 2: คำนวณตามประเภทวัสดุ -->
<div id="tab-material" class="tab-content">
  <div class="calc-section">
    <h3>📐 ขนาดพื้นที่</h3>
    <div class="input-row">
      <div class="input-group">
        <label>กว้าง (ม.)</label>
        <input type="number" id="mat-width" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>ยาว (ม.)</label>
        <input type="number" id="mat-length" value="4" min="0" step="0.01">
      </div>
      <div class="input-group">
        <label>หนา (ม.)</label>
        <input type="number" id="mat-thickness" value="0.10" min="0" step="0.01">
      </div>
    </div>
  </div>

  <div class="calc-section">
    <h3>🔨 เลือกประเภทงาน</h3>
    <div class="job-buttons">
      <button class="job-btn" data-job="concrete">🏗️ เทพื้น</button>
      <button class="job-btn" data-job="tile">🔲 กระเบื้อง</button>
      <button class="job-btn" data-job="ceiling">🎯 ฝ้าเพดาน</button>
      <button class="job-btn" data-job="roofing">🏠 มุงหลังคา</button>
    </div>
    
    <div class="roof-input" id="roofing-input">
      <div class="input-row">
        <div class="input-group">
          <label>ความยาวสันหลังคา (ม.)</label>
          <input type="number" id="roof-ridge" value="5" min="0" step="0.01">
        </div>
      </div>
    </div>
  </div>

  <div class="calc-section" id="materials-result" style="display: none;">
    <h3>📋 รายการวัสดุและราคา</h3>
    <table class="material-table">
      <thead>
        <tr>
          <th>วัสดุ</th>
          <th>ปริมาณ</th>
          <th>ราคา/หน่วย</th>
          <th>รวม</th>
        </tr>
      </thead>
      <tbody id="materials-body"></tbody>
      <tfoot>
        <tr class="total-row">
          <td colspan="3">ยอดรวม</td>
          <td id="total-price">0 บาท</td>
        </tr>
      </tfoot>
    </table>
    <div class="action-buttons">
      <button class="action-btn btn-pdf" onclick="window.print()">📄 Download PDF</button>
      <button class="action-btn btn-line" onclick="orderLine()">💬 สั่งซื้อ LINE</button>
    </div>
  </div>

  <div class="empty-state" id="materials-empty">
    <p>กรุณาเลือกประเภทงานเพื่อคำนวณวัสดุ</p>
  </div>
</div>

<!-- Tab 3: กำหนดเอง (ยังไม่ทำ) -->
<div id="tab-custom" class="tab-content">
  <div class="calc-section">
    <div class="empty-state">
      <p> Coming Soon - กำลังพัฒนา...</p>
    </div>
  </div>
</div>

<script>
// Price cache
function getPrice(name) {
  if (!window.siamCosmoPrices || window.siamCosmoPrices.error || !Array.isArray(window.siamCosmoPrices)) {
    return null;
  }
  for (let p of window.siamCosmoPrices) {
    if (p.productname && p.productname.toLowerCase().includes(name.toLowerCase())) {
      return parseFloat(p.productsale1 || p.productcost || 0);
    }
  }
  return null;
}

function fmt(num) {
  if (num === null || num === undefined || isNaN(num)) return '0';
  return num.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

// Tab switching
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    if (btn.disabled) return;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// Tab 1: Real-time calculation
function calculateArea() {
  const w = parseFloat(document.getElementById('area-width').value) || 0;
  const l = parseFloat(document.getElementById('area-length').value) || 0;
  const h = parseFloat(document.getElementById('area-height').value) || 0;

  document.getElementById('res-rectangle').textContent = fmt(w * l) + ' ตร.ม.';
  document.getElementById('res-triangle').textContent = fmt(w * h * 0.5) + ' ตร.ม.';
  document.getElementById('res-trapezoid').textContent = fmt((w + l) * h * 0.5) + ' ตร.ม.';
  document.getElementById('res-circle').textContent = fmt(Math.PI * Math.pow(w / 2, 2)) + ' ตร.ม.';
  document.getElementById('res-volume').textContent = fmt(w * l * h) + ' ลบ.ม.';
}

['area-width', 'area-length', 'area-height'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', calculateArea);
});

// Tab 2: Material calculation
function calculateMaterials() {
  const w = parseFloat(document.getElementById('mat-width').value) || 0;
  const l = parseFloat(document.getElementById('mat-length').value) || 0;
  const t = parseFloat(document.getElementById('mat-thickness').value) || 0.1;
  const ridge = parseFloat(document.getElementById('roof-ridge').value) || 0;
  
  const area = w * l;
  const volume = w * l * t;

  const activeJob = document.querySelector('.job-btn.active');
  if (!activeJob) return;

  const job = activeJob.dataset.job;
  let materials = [];

  // Price fallbacks
  const prices = {
    readymix: getPrice('ปูน') || getPrice('คอนกรีต') || 1500,
    sand: getPrice('ทราย') || 660,
    wiremesh: getPrice('ไวร์เมช') || getPrice('ตะแกรง') || 120,
    tile: getPrice('กระเบื้อง') || 85,
    glue: getPrice('กาว') || 78,
    grout: getPrice('ยาแนว') || 45,
    gypsum: getPrice('ยิปซัม') || getPrice('Gypsum') || 180,
    cchannel: getPrice('C-Line') || getPrice('โครงคร่าว') || 85,
    nail: getPrice('ตะปู') || getPrice('สกรู') || 68,
    roofTile: getPrice('กระเบื้องลอน') || 22,
    roofCap: getPrice('ครอบ') || 52
  };

  if (job === 'concrete') {
    materials = [
      { name: 'ปูนผสมเสร็จ (คิว)', qty: Math.ceil(volume * 10) / 10, price: prices.readymix, unit: 'คิว' },
      { name: 'ทรายรองพื้น 5 ซม.', qty: Math.ceil(area * 0.05 * 10) / 10, price: prices.sand, unit: 'คิว' },
      { name: 'เหล็กไวร์เมช', qty: Math.ceil(area * 10) / 10, price: prices.wiremesh, unit: 'ตร.ม.' }
    ];
  } else if (job === 'tile') {
    materials = [
      { name: 'กระเบื้อง', qty: Math.ceil(area * 10) / 10, price: prices.tile, unit: 'ตร.ม.' },
      { name: 'ปูนกาว', qty: Math.ceil(area / 4.5 * 10) / 10, price: prices.glue, unit: 'กก.' },
      { name: 'ยาแนว', qty: Math.ceil(area / 4 * 10) / 10, price: prices.grout, unit: 'กก.' }
    ];
  } else if (job === 'ceiling') {
    materials = [
      { name: 'แผ่นยิปซัม 1.2×2.4 ม.', qty: Math.ceil(area / 2.88 * 10) / 10, price: prices.gypsum, unit: 'แผ่น' },
      { name: 'โครงคร่าว C-Line', qty: Math.ceil(area * 1.5 * 10) / 10, price: prices.cchannel, unit: 'เส้น' },
      { name: 'ตะปูยิง/สกรู', qty: Math.ceil(area * 18), price: prices.nail / 100, unit: 'ตัว' }
    ];
  } else if (job === 'roofing') {
    materials = [
      { name: 'กระเบื้องลอนคู่', qty: Math.ceil(area * 2.2), price: prices.roofTile, unit: 'แผ่น' },
      { name: 'ครอบหลังคา', qty: Math.ceil(ridge * 3.3), price: prices.roofCap, unit: 'ตัว' }
    ];
  }

  materials = materials.map(m => ({
    ...m,
    total: (m.qty * m.price)
  }));

  const tbody = document.getElementById('materials-body');
  tbody.innerHTML = materials.map(m => `
    <tr>
      <td>${m.name}</td>
      <td class="num">${fmt(m.qty)} ${m.unit}</td>
      <td class="num">${fmt(m.price)} บาท</td>
      <td class="num">${fmt(m.total)} บาท</td>
    </tr>
  `).join('');

  const total = materials.reduce((sum, m) => sum + m.total, 0);
  document.getElementById('total-price').textContent = fmt(total) + ' บาท';
  document.getElementById('materials-result').style.display = 'block';
  document.getElementById('materials-empty').style.display = 'none';
}

// Job buttons
document.querySelectorAll('.job-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.job-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    
    document.getElementById('roofing-input').classList.toggle('show', btn.dataset.job === 'roofing');
    
    document.getElementById('materials-result').style.display = 'none';
    document.getElementById('materials-empty').style.display = 'none';
    
    calculateMaterials();
  });
});

// Material input listeners
['mat-width', 'mat-length', 'mat-thickness', 'roof-ridge'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', () => {
    if (document.querySelector('.job-btn.active')) {
      calculateMaterials();
    }
  });
});

// LINE order
function orderLine() {
  const w = parseFloat(document.getElementById('mat-width').value) || 0;
  const l = parseFloat(document.getElementById('mat-length').value) || 0;
  const t = parseFloat(document.getElementById('mat-thickness').value) || 0;
  const total = document.getElementById('total-price').textContent;
  
  const activeJob = document.querySelector('.job-btn.active');
  const jobNames = {
    concrete: 'เทพื้นคอนกรีต',
    tile: 'ปูกระเบื้อง',
    ceiling: 'ฝ้าเพดาน',
    roofing: 'มุงหลังคา'
  };
  const jobName = activeJob ? jobNames[activeJob.dataset.job] : '';
  
  const message = `สวัสดีครับ สั่งซื้อวัสดุก่อสร้าง%0A%0Aประเภทงาน: ${jobName}%0Aขนาด: ${w}m × ${l}m × ${t}m%0Aยอดรวม: ${total}%0A%0Aกรุณาติดต่อกลับครับ`;
  
  window.open(`https://line.me/R/ti/p/@siamcosmo?text=${message}`, '_blank');
}

// Initial calculations
setTimeout(() => {
  calculateArea();
  calculateMaterials();
}, 500);
</script>

</body>
</html>