<script>
// Wait for prices to load
function getPrice(name) {
  if (!window.siamCosmoPrices || window.siamCosmoPrices.error) {
    return null;
  }
  const prices = window.siamCosmoPrices;
  for (let p of prices) {
    if (p.productname && p.productname.includes(name)) {
      return parseFloat(p.productsale1 || p.productcost || 0);
    }
  }
  return null;
}

function fmt(num) {
  return num.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

// Tab switching
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// Real-time calculation
function calculateAll() {
  const w = parseFloat(document.getElementById('input-width').value) || 0;
  const l = parseFloat(document.getElementById('input-length').value) || 0;
  const h = parseFloat(document.getElementById('input-height').value) || 0;
  const t = parseFloat(document.getElementById('input-thickness').value) || 0.1;

  // 5 shapes
  document.getElementById('res-rectangle').textContent = fmt(w * l) + ' ตร.ม.';
  document.getElementById('res-triangle').textContent = fmt(w * h * 0.5) + ' ตร.ม.';
  document.getElementById('res-trapezoid').textContent = fmt((w + l) * h * 0.5) + ' ตร.ม.';
  document.getElementById('res-circle').textContent = fmt(Math.PI * Math.pow(w / 2, 2)) + ' ตร.ม.';
  document.getElementById('res-volume').textContent = fmt(w * l * t) + ' ลบ.ม.';

  // Auto calculate materials if job selected
  const activeJob = document.querySelector('.job-btn.active');
  if (activeJob) {
    calculateMaterials(activeJob.dataset.job, w, l, h, t);
  }
}

// Job buttons
document.querySelectorAll('.job-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.job-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Show paint inputs if paint job
    document.getElementById('paint-inputs').style.display = btn.dataset.job === 'paint' ? 'block' : 'none';
    document.getElementById('materials-section').style.display = 'block';

    calculateAll();
  });
});

// Add input listeners
['input-width', 'input-length', 'input-height', 'input-thickness', 'paint-door', 'paint-window'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', calculateAll);
});

function calculateMaterials(job, w, l, h, t) {
  const area = w * l;
  const volume = w * l * t;
  let materials = [];

  const prices = {
    cement: getPrice('ปูน') || 188,
    sand: getPrice('ทราย') || 660,
    stone: getPrice('หิน') || 730,
    tile: getPrice('กระเบื้อง') || 85,
    glue: getPrice('กาว') || 78,
    grout: getPrice('ยาแนว') || 45,
    wood: getPrice('ไม้อัด') || 482,
    nail: getPrice('ตะปู') || 68,
    primer: getPrice('รองพื้น') || 380,
    paint: getPrice('สี TOA') || 1505
  };

  if (job === 'concrete') {
    const vol = volume;
    materials = [
      { name: 'ปูนซีเมนต์ 50 กก.', qty: Math.ceil(vol * 7), price: prices.cement, unit: 'ถุง' },
      { name: 'ทรายหยาบ', qty: Math.ceil(vol * 0.5), price: prices.sand, unit: 'ครึ่งกระบะ' },
      { name: 'หิน 3/4', qty: Math.ceil(vol * 0.8), price: prices.stone, unit: 'ครึ่งคัน' },
      { name: 'ทรายรองพื้น 5 ซม.', qty: Math.ceil(area * 0.05 * 10) / 10, price: prices.sand / 2, unit: 'ครึ่งกระบะ' }
    ];
  } else if (job === 'tile') {
    materials = [
      { name: 'กระเบื้อง 60x60', qty: Math.ceil(area * 3 * 1.1), price: prices.tile, unit: 'แผ่น' },
      { name: 'กาวซีเมนต์', qty: Math.ceil(area * 4.5 * 10) / 10, price: prices.glue, unit: 'กก.' },
      { name: 'ยาแนว', qty: Math.ceil(area * 0.3 * 10) / 10, price: prices.grout, unit: 'กก.' }
    ];
  } else if (job === 'wood') {
    materials = [
      { name: 'ไม้อัดดำ 15 มิล', qty: Math.ceil(area * 1.15 * 10) / 10, price: prices.wood, unit: 'แผ่น' },
      { name: 'ตะปู', qty: Math.ceil(area * 0.2 * 10) / 10, price: prices.nail, unit: 'กก.' },
      { name: 'สีรองพื้นไม้', qty: Math.ceil(area * 0.1 * 10) / 10, price: prices.primer, unit: 'ลิตร' }
    ];
  } else if (job === 'paint') {
    const door = parseFloat(document.getElementById('paint-door').value) || 0;
    const win = parseFloat(document.getElementById('paint-window').value) || 0;
    const realArea = Math.max(0, area - door - win);
    materials = [
      { name: 'สีทาบ้าน 2.5 GL', qty: Math.ceil(realArea * 0.13 / 2.5 * 10) / 10, price: prices.paint, unit: 'แกลลอน' },
      { name: 'สีรองพื้น', qty: Math.ceil(realArea * 0.07 * 10) / 10, price: prices.primer, unit: 'ลิตร' }
    ];
  }

  // Add 10% buffer and calculate
  materials = materials.map(m => ({
    ...m,
    qty: Math.ceil(m.qty * 1.1 * 10) / 10,
    total: m.qty * m.price
  }));

  // Render table
  const tbody = document.getElementById('materials-body');
  tbody.innerHTML = materials.map(m => `
    <tr>
      <td>${m.name}</td>
      <td class="num">${fmt(m.qty)} ${m.unit}</td>
      <td class="num">${fmt(m.price)} บาท</td>
      <td class="num">${fmt(m.total)} บาท</td>
    </tr>
  `).join('');

  const total = materials.reduce((sum, m) => sum + m.total, 0);
  document.getElementById('total-price').textContent = fmt(total) + ' บาท';
}

// AI Bot - Shape selector
let currentShape = 'rectangle';
document.querySelectorAll('.shape-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.shape-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentShape = btn.dataset.shape;
    document.querySelectorAll('.shape-inputs').forEach(div => div.style.display = 'none');
    document.getElementById(currentShape + '-inputs').style.display = 'flex';
  });
});

// AI Bot - Calculate
document.getElementById('ai-calc-btn').addEventListener('click', () => {
  let result = '';
  if (currentShape === 'rectangle') {
    const w = parseFloat(document.getElementById('ai-width').value) || 0;
    const l = parseFloat(document.getElementById('ai-length').value) || 0;
    result = `พื้นที่สี่เหลี่ยม = ${fmt(w * l)} ตร.ม.`;
  } else if (currentShape === 'triangle') {
    const b = parseFloat(document.getElementById('ai-base').value) || 0;
    const h = parseFloat(document.getElementById('ai-height').value) || 0;
    result = `พื้นที่สามเหลี่ยม = ${fmt(b * h * 0.5)} ตร.ม.`;
  } else if (currentShape === 'circle') {
    const r = parseFloat(document.getElementById('ai-radius').value) || 0;
    result = `พื้นที่วงกลม = ${fmt(Math.PI * r * r)} ตร.ม.`;
  } else if (currentShape === 'trapezoid') {
    const p1 = parseFloat(document.getElementById('ai-parallel1').value) || 0;
    const p2 = parseFloat(document.getElementById('ai-parallel2').value) || 0;
    const h = parseFloat(document.getElementById('ai-height').value) || 0;
    result = `พื้นที่สี่เหลี่ยมคางหมู = ${fmt((p1 + p2) * h * 0.5)} ตร.ม.`;
  }
  document.getElementById('ai-result').textContent = result;
});

// AI Bot - Chat
const chatForm = document.getElementById('chat-form');
const chatMessages = document.getElementById('chat-messages');

chatForm?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const input = chatForm.querySelector('input');
  const msg = input.value.trim();
  if (!msg) return;

  chatMessages.innerHTML += `<div class="message user">${msg}</div>`;
  input.value = '';

  try {
    const res = await fetch('/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ service_key: 'calculator', message: msg })
    });
    const data = await res.json();
    if (data.success) {
      chatMessages.innerHTML += `<div class="message bot">ขอบคุณที่สอบถามครับ! กรุณาใช้เครื่องมือคำนวณด้านบน หรือติดต่อผู้ให้บริการได้เลยครับ</div>`;
    }
  } catch (err) {
    chatMessages.innerHTML += `<div class="message bot">ขออภัย มีข้อผิดพลาด กรุณาลองใหม่ครับ</div>`;
  }
  chatMessages.scrollTop = chatMessages.scrollHeight;
});

// Initial calculation
setTimeout(calculateAll, 500);
</script>

